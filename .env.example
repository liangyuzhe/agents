# ===== LLM Model Configuration =====

# Model type selectors: ark | openai | qwen | gemini
CHAT_MODEL_TYPE=ark
INTENT_MODEL_TYPE=ark
EMBEDDING_MODEL_TYPE=qwen
VECTOR_DB_TYPE=MILVUS

# ----- Ark (Doubao) -----
ARK_KEY=your-ark-api-key
ARK_CHAT_MODEL=doubao-seed-2-0-code-preview-260215
ARK_EMBEDDING_MODEL=ep-your-embedding-endpoint

# ----- OpenAI -----
OPENAI_KEY=your-api-key
OPENAI_CHAT_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=your-embedding-model

# ----- Qwen (DashScope) -----
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_KEY=sk-your-qwen-key
QWEN_CHAT_MODEL=your-chat-model
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ----- Gemini -----
GEMINI_KEY=your-api-key
GEMINI_CHAT_MODEL=your-chat-model
GEMINI_EMBEDDING_MODEL=your-embedding-model

# ----- DeepSeek -----
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_KEY=your-deepseek-key
DEEPSEEK_CHAT_MODEL=your-chat-model
DEEPSEEK_EMBEDDING_MODEL=your-embedding-model
DEEPSEEK_TIMEOUT=30

# ===== Vector Store: Milvus =====
MILVUS_ADDR=localhost:19530
MILVUS_USERNAME=root
MILVUS_PASSWORD=milvus
MILVUS_SIMILARITY_THRESHOLD=0.7
MILVUS_COLLECTION_NAME=GoAgent
TOPK=5

# ===== Elasticsearch =====
ES_ADDRESS=http://localhost:9200
ES_USERNAME=your-username
ES_PASSWORD=your-password
ES_INDEX=go_agent_docs

# ===== Redis (checkpointer & caching) =====
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MySQL (audit log) =====
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=go_agent_audit

# ===== LangSmith (tracing) =====
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_URL=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# ===== RAG Parameters =====
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ===== Agent Memory =====
MEMORY_MAX_TOKENS=4000
MEMORY_SUMMARY_THRESHOLD=3000

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8080
